#!/usr/bin/env -S deno run --allow-run --allow-read

function toPath(url: URL | string): string {
  const path = new URL(url).pathname;
  return decodeURIComponent(path);
}

const scriptDir = toPath(new URL('.', import.meta.url));
const repoRoot = await Deno.realPath(`${scriptDir}/../..`);
const vault = 'rbff';

function usage() {
  console.log('rbff open [path]  - open repo or specific file/folder in Obsidian');
}

async function exists(path: string): Promise<boolean> {
  try {
    await Deno.stat(path);
    return true;
  } catch {
    return false;
  }
}

async function statPath(path: string): Promise<Deno.FileInfo | null> {
  try {
    return await Deno.stat(path);
  } catch {
    return null;
  }
}

async function runObsidian(args: string[]): Promise<boolean> {
  const cmd = new Deno.Command('obsidian', {
    args,
    stdin: 'inherit',
    stdout: 'inherit',
    stderr: 'inherit',
  });
  const { success } = await cmd.spawn().status;
  return success;
}

async function openObsidian(target?: string): Promise<void> {
  let fullPath = target ?? repoRoot;
  if (!fullPath.startsWith('/')) {
    fullPath = `${repoRoot}/${fullPath}`;
  }
  if (!await exists(fullPath)) {
    console.error(`rbff: path not found: ${fullPath}`);
    Deno.exit(1);
  }

  let rel = fullPath.startsWith(repoRoot) ? fullPath.slice(repoRoot.length + 1) : '';
  rel = rel.replace(/^\/+/, '');

  const info = await statPath(fullPath);
  if (!info) {
    console.error(`rbff: unable to stat path: ${fullPath}`);
    Deno.exit(1);
  }

  let success = false;
  if (rel.length === 0 || info.isDirectory) {
    // The CLI `open` command targets files, so opening the vault is the closest
    // match for the repo root or a directory target.
    success = await runObsidian([`vault=${vault}`]);
  } else {
    success = await runObsidian([`vault=${vault}`, 'open', `path=${rel}`]);
  }

  if (!success) {
    console.error('rbff: failed to open Obsidian via the official CLI');
    console.error('rbff: make sure Obsidian CLI is enabled in Settings > General');
    Deno.exit(1);
  }
}

const [cmd, ...rest] = Deno.args;

switch (cmd ?? 'open') {
  case 'open':
  case '':
    await openObsidian(rest[0]);
    break;
  case 'help':
  case '--help':
  case '-h':
    usage();
    break;
  default:
    console.error(`rbff: unknown command: ${cmd}`);
    Deno.exit(1);
}
